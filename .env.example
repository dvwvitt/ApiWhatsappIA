# ============================================
# WhatsApp Business API - Configuracion
# ============================================
# Copia este archivo como .env y completa los valores
# cp .env.example .env

# --- Meta / Facebook App ---
M4D_APP_ID=TU_APP_ID
M4D_APP_SECRET=TU_APP_SECRET
WA_PHONE_NUMBER_ID=TU_PHONE_NUMBER_ID
WA_BUSINESS_ACCOUNT_ID=TU_BUSINESS_ACCOUNT_ID
CLOUD_API_ACCESS_TOKEN=TU_ACCESS_TOKEN
CLOUD_API_VERSION=v19.0
WHATSAPP_BUSINESS_NUMBER=+57XXXXXXXXXX

# --- Ngrok ---
NGROK_AUTH_TOKEN=

# --- Webhook ---
WEBHOOK_ENDPOINT=/webhook/whatsapp
WEBHOOK_VERIFICATION_TOKEN=TU_TOKEN_SEGURO_AQUI

# --- Servidor ---
PORT=3000

# --- OpenClaw (opcional) ---
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_API_TOKEN=

# --- Logging ---
LOG_LEVEL=info
LOG_FILE=logs/whatsapp-middleware.log
